{
  "extends": [
    "config:recommended",
    ":preserveSemverRanges",
    ":rebaseStalePrs",
    ":pinAllExceptPeerDependencies"
  ],
  "labels": ["dependencies"],
  "timezone": "UTC",
  "prConcurrentLimit": 6,
  "ignorePaths": ["**/dist/**", "apps/**/prisma/migrations/**"],
  "packageRules": [
    {
      "matchDepTypes": ["devDependencies"],
      "automerge": true,
      "automergeType": "branch"
    },
    {
      "matchDepTypes": ["dependencies"],
      "matchUpdateTypes": ["minor", "patch", "pin", "digest"],
      "automerge": true,
      "automergeType": "branch"
    },
    {
      "groupName": "nx monorepo packages",
      "automerge": true,
      "automergeType": "branch",
      "matchPackageNames": [
        "/^@nrwl//",
        "/^nx/",
        "/^@nrwl/",
        "/^@nx//",
        "/^@eslint$/",
        "/^eslint/",
        "/^eslint-/",
        "/^eslint-plugin-/",
        "/^eslint-config-/",
        "/^typescript-eslint/"
      ]
    },
    {
      "groupName": "nestjs packages",
      "automerge": true,
      "automergeType": "branch",
      "matchPackageNames": ["@nestjs/{/,}**"]
    },
    {
      "matchManagers": ["github-actions"],
      "groupName": "github-actions",
      "automerge": true,
      "automergeType": "branch"
    },
    {
      "matchPackageNames": ["prisma", "@prisma/client", "@prisma/adapter-pg"],
      "groupName": "prisma packages",
      "automerge": true,
      "automergeType": "branch"
    }
  ]
}
