# Local development Docker Compose defaults.
# Loaded by: infra:serve, infra:stop, infra:clean.

# Main application Postgres database.
POSTGRES_USER=trading
POSTGRES_PASSWORD=trading_pass
POSTGRES_DB=trading_db

# TimescaleDB reserved for market data workloads.
TIMESCALE_USER=timescale
TIMESCALE_PASSWORD=timescale_pass
TIMESCALE_DB=timescale_db
