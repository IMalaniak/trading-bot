// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider     = "prisma-client"
  output       = "../src/prisma/generated"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

model Instrument {
  id             String   @id @default(uuid())
  assetClass     Int
  symbol         String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  venue          String
  externalSymbol String?
  portfolioInstrumentConfigs PortfolioInstrumentConfig[]
  portfolioOrders PortfolioOrder[]
  portfolioFills PortfolioFill[]
  portfolioPositions PortfolioPosition[]

  @@unique([symbol, venue])
}

model Portfolio {
  id                  String                        @id
  name                String
  exposureCapNotional Decimal                       @db.Decimal(36, 18)
  isActive            Boolean                       @default(true)
  strategyId          String?
  createdAt           DateTime                      @default(now())
  updatedAt           DateTime                      @updatedAt
  strategy            Strategy?                     @relation(fields: [strategyId], references: [id], onDelete: SetNull)
  instrumentConfigs   PortfolioInstrumentConfig[]
  candidateRecords    PortfolioSignalCandidateRecord[]
  decisions           RiskDecision[]
  reservations        ExposureReservation[]
  portfolioOrders     PortfolioOrder[]
  portfolioFills      PortfolioFill[]
  positions           PortfolioPosition[]
  summarySnapshots    PortfolioSummarySnapshot[]
  auditLogs           RiskConfigAuditLog[]
}

model PortfolioInstrumentConfig {
  id                       String    @id @default(uuid())
  portfolioId              String
  instrumentId             String
  enabled                  Boolean   @default(true)
  targetNotional           Decimal   @db.Decimal(36, 18)
  maxTradeNotional         Decimal   @db.Decimal(36, 18)
  maxPositionNotional      Decimal   @db.Decimal(36, 18)
  maxOpenTrades            Int?
  maxDailyTurnoverNotional Decimal?  @db.Decimal(36, 18)
  cooldownSeconds          Int?
  maxConsecutiveRejections Int?
  createdAt                DateTime  @default(now())
  updatedAt                DateTime  @updatedAt
  portfolio                Portfolio  @relation(fields: [portfolioId], references: [id], onDelete: Cascade)
  instrument               Instrument @relation(fields: [instrumentId], references: [id], onDelete: Cascade)
  auditLogs                RiskConfigAuditLog[]

  @@unique([portfolioId, instrumentId])
  @@index([instrumentId, enabled])
}

enum SignalReceiptStatus {
  PENDING
  FANNED_OUT
  NO_ELIGIBLE_PORTFOLIOS
  UNKNOWN_INSTRUMENT
}

model SignalReceipt {
  id                   String                        @id @default(uuid())
  sourceEventId        String                        @unique
  signalId             String
  instrumentId         String
  kafkaKey             String
  receivedAt           DateTime
  status               SignalReceiptStatus           @default(PENDING)
  eligiblePortfolioCount Int                        @default(0)
  createdAt            DateTime                      @default(now())
  updatedAt            DateTime                      @updatedAt
  candidateRecords     PortfolioSignalCandidateRecord[]
}

enum PortfolioSignalCandidateStatus {
  PENDING
  DECIDED
}

model PortfolioSignalCandidateRecord {
  id                     String                         @id @default(uuid())
  candidateIdempotencyKey String                       @unique
  signalReceiptId        String
  sourceEventId          String
  portfolioId            String
  instrumentId           String
  signalId               String
  side                   Int
  referencePrice         Decimal                        @db.Decimal(36, 18)
  targetNotionalSnapshot Decimal                        @db.Decimal(36, 18)
  signalTimestamp        DateTime
  receivedAt             DateTime
  status                 PortfolioSignalCandidateStatus @default(PENDING)
  createdAt              DateTime                       @default(now())
  updatedAt              DateTime                       @updatedAt
  signalReceipt          SignalReceipt                  @relation(fields: [signalReceiptId], references: [id], onDelete: Cascade)
  portfolio              Portfolio                      @relation(fields: [portfolioId], references: [id], onDelete: Cascade)
  decision               RiskDecision?

  @@index([portfolioId, createdAt])
  @@index([sourceEventId])
}

enum RiskDecisionStatus {
  APPROVED
  REJECTED
}

enum RiskDecisionReasonCode {
  SUBSCRIPTION_DISABLED
  TRADE_CAP_EXCEEDED
  INSTRUMENT_EXPOSURE_CAP_EXCEEDED
  PORTFOLIO_EXPOSURE_CAP_EXCEEDED
  MAX_OPEN_TRADES_EXCEEDED
  DAILY_TURNOVER_LIMIT_EXCEEDED
  STRATEGY_SIDE_FILTER
  STRATEGY_TIME_FILTER
  STRATEGY_COOLDOWN_FILTER
}

model RiskDecision {
  id                     String                  @id @default(uuid())
  candidateRecordId      String                  @unique
  candidateIdempotencyKey String                 @unique
  sourceEventId          String
  portfolioId            String
  instrumentId           String
  decision               RiskDecisionStatus
  reasonCodes            RiskDecisionReasonCode[]
  requestedNotional      Decimal                 @db.Decimal(36, 18)
  requestedQuantity      Decimal                 @db.Decimal(36, 18)
  referencePrice         Decimal                 @db.Decimal(36, 18)
  emittedTopic           String
  decidedAt              DateTime
  createdAt              DateTime                @default(now())
  updatedAt              DateTime                @updatedAt
  candidateRecord        PortfolioSignalCandidateRecord @relation(fields: [candidateRecordId], references: [id], onDelete: Cascade)
  portfolio              Portfolio               @relation(fields: [portfolioId], references: [id], onDelete: Cascade)
  reservation            ExposureReservation?

  @@index([portfolioId, decision])
  @@index([portfolioId, instrumentId, decision])
}

enum ExposureReservationStatus {
  ACTIVE
  RELEASED
}

model ExposureReservation {
  id                     String                    @id @default(uuid())
  riskDecisionId         String                    @unique
  candidateIdempotencyKey String                   @unique
  portfolioId            String
  instrumentId           String
  reservedNotional       Decimal                   @db.Decimal(36, 18)
  reservedQuantity       Decimal                   @db.Decimal(36, 18)
  status                 ExposureReservationStatus @default(ACTIVE)
  createdAt              DateTime                  @default(now())
  updatedAt              DateTime                  @updatedAt
  releasedAt             DateTime?
  riskDecision           RiskDecision              @relation(fields: [riskDecisionId], references: [id], onDelete: Cascade)
  portfolio              Portfolio                 @relation(fields: [portfolioId], references: [id], onDelete: Cascade)

  @@index([portfolioId, status])
  @@index([portfolioId, instrumentId, status])
}

enum PortfolioOrderStatus {
  PLACED
  PARTIALLY_FILLED
  FILLED
}

model PortfolioOrder {
  id                      String               @id
  approvalEventId         String               @unique
  candidateIdempotencyKey String               @unique
  sourceEventId           String
  portfolioId             String
  instrumentId            String
  signalId                String
  side                    Int
  status                  PortfolioOrderStatus
  finalSequence           Int?
  firstFilledAt           DateTime
  lastFilledAt            DateTime
  createdAt               DateTime             @default(now())
  updatedAt               DateTime             @updatedAt
  portfolio               Portfolio            @relation(fields: [portfolioId], references: [id], onDelete: Cascade)
  instrument              Instrument           @relation(fields: [instrumentId], references: [id], onDelete: Cascade)
  fills                   PortfolioFill[]

  @@index([portfolioId, status])
  @@index([portfolioId, instrumentId])
}

model PortfolioFill {
  id                       String               @id
  kafkaEventId             String               @unique
  orderId                  String
  approvalEventId          String
  sourceEventId            String
  candidateIdempotencyKey  String
  portfolioId              String
  instrumentId             String
  signalId                 String
  side                     Int
  sequence                 Int
  fillNotional             Decimal              @db.Decimal(36, 18)
  fillQuantity             Decimal              @db.Decimal(36, 18)
  fillPrice                Decimal              @db.Decimal(36, 18)
  cumulativeFilledNotional Decimal              @db.Decimal(36, 18)
  cumulativeFilledQuantity Decimal              @db.Decimal(36, 18)
  orderStatus              PortfolioOrderStatus
  filledAt                 DateTime
  receivedAt               DateTime
  createdAt                DateTime             @default(now())
  updatedAt                DateTime             @updatedAt
  order                    PortfolioOrder       @relation(fields: [orderId], references: [id], onDelete: Cascade)
  portfolio                Portfolio            @relation(fields: [portfolioId], references: [id], onDelete: Cascade)
  instrument               Instrument           @relation(fields: [instrumentId], references: [id], onDelete: Cascade)

  @@unique([orderId, sequence])
  @@index([portfolioId, instrumentId, filledAt])
  @@index([candidateIdempotencyKey])
}

model PortfolioPosition {
  id                String    @id @default(uuid())
  portfolioId       String
  instrumentId      String
  quantity          Decimal   @db.Decimal(36, 18)
  averageEntryPrice Decimal   @db.Decimal(36, 18)
  exposureNotional  Decimal   @db.Decimal(36, 18)
  lastFillId        String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  portfolio         Portfolio @relation(fields: [portfolioId], references: [id], onDelete: Cascade)
  instrument        Instrument @relation(fields: [instrumentId], references: [id], onDelete: Cascade)

  @@unique([portfolioId, instrumentId])
  @@index([portfolioId, exposureNotional])
}

model PortfolioSummarySnapshot {
  id                                    String    @id @default(uuid())
  portfolioId                           String
  sourceFillId                          String    @unique
  orderId                               String
  instrumentId                          String
  aggregateExposureNotional             Decimal   @db.Decimal(36, 18)
  openPositionCount                     Int
  changedPositionQuantity               Decimal   @db.Decimal(36, 18)
  changedPositionAverageEntryPrice      Decimal   @db.Decimal(36, 18)
  changedPositionExposureNotional       Decimal   @db.Decimal(36, 18)
  updatedAt                             DateTime
  createdAt                             DateTime  @default(now())
  portfolio                             Portfolio @relation(fields: [portfolioId], references: [id], onDelete: Cascade)

  @@index([portfolioId, updatedAt])
}

enum OutboxEventStatus {
  PENDING
  IN_FLIGHT
  DISPATCHED
  FAILED
}

model OutboxEvent {
  id            String   @id @default(uuid())
  topic         String
  key           String
  value         Bytes
  headers       Json?
  status        OutboxEventStatus @default(PENDING)
  attempts      Int      @default(0)
  nextAttemptAt DateTime @default(now())
  lastError     String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  dispatchedAt  DateTime?

  @@index([status, nextAttemptAt])
}

// ─── Strategy ────────────────────────────────────────────────────────────────

model Strategy {
  id              String     @id @default(uuid())
  name            String     @unique
  description     String?
  allowedSides    Int[]
  minIntervalSecs Int?
  activeTimeStart String?
  activeTimeEnd   String?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
  portfolios      Portfolio[]
}

// ─── Risk Config Audit Log ────────────────────────────────────────────────────

enum RiskConfigAuditEntityType {
  PORTFOLIO
  INSTRUMENT_CONFIG
}

model RiskConfigAuditLog {
  id                        String                   @id @default(uuid())
  entityType                RiskConfigAuditEntityType
  portfolioId               String
  portfolioInstrumentConfigId String?
  field                     String
  oldValue                  String?
  newValue                  String?
  changedAt                 DateTime                 @default(now())
  portfolio                 Portfolio                @relation(fields: [portfolioId], references: [id], onDelete: Cascade)
  portfolioInstrumentConfig PortfolioInstrumentConfig? @relation(fields: [portfolioInstrumentConfigId], references: [id], onDelete: SetNull)

  @@index([portfolioId, changedAt])
  @@index([portfolioInstrumentConfigId, changedAt])
}
