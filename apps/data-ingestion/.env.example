# data-ingestion — local environment variables
#
# Copy this file to .env for local development.
# Never commit .env with real credentials.
#
# Shared variables (KAFKA_BROKERS, *_GRPC_URL, etc.) are loaded from the
# workspace-root .env automatically — only service-specific overrides belong here.

# ── Database ─────────────────────────────────────────────────────────────────
DATA_INGESTION_DATABASE_URL=postgresql://trading:trading@localhost:5434/trading
DATABASE_MAX_CONNECTIONS=10

# ── Kafka ─────────────────────────────────────────────────────────────────────
KAFKA_CONSUMER_GROUP_ID=data-ingestion
# Comma-separated kline intervals to subscribe to for each new instrument.
KAFKA_DEFAULT_INTERVALS=1m

# ── gRPC ──────────────────────────────────────────────────────────────────────
DATA_INGESTION_GRPC_PORT=50054

# ── Observability ─────────────────────────────────────────────────────────────
DATA_INGESTION_METRICS_PORT=9104
LOG_LEVEL=info
