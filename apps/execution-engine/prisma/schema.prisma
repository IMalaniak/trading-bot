generator client {
  provider     = "prisma-client"
  output       = "../src/prisma/generated"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
  schemas  = ["execution_engine"]
}

enum ExecutionOrderStatus {
  PLACED
  PARTIALLY_FILLED
  FILLED

  @@schema("execution_engine")
}

model ExecutionOrder {
  id                      String               @id
  approvalEventId         String               @unique
  candidateIdempotencyKey String               @unique
  sourceEventId           String
  portfolioId             String
  instrumentId            String
  signalId                String
  side                    Int
  requestedNotional       Decimal              @db.Decimal(36, 18)
  requestedQuantity       Decimal              @db.Decimal(36, 18)
  referencePrice          Decimal              @db.Decimal(36, 18)
  status                  ExecutionOrderStatus @default(PLACED)
  approvedAt              DateTime
  placedAt                DateTime
  createdAt               DateTime             @default(now())
  updatedAt               DateTime             @updatedAt
  fills                   ExecutionFill[]

  @@index([portfolioId, status])
  @@index([portfolioId, instrumentId])
  @@schema("execution_engine")
}

model ExecutionFill {
  id                       String               @id
  orderId                  String
  portfolioId              String
  instrumentId             String
  sequence                 Int
  fillNotional             Decimal              @db.Decimal(36, 18)
  fillQuantity             Decimal              @db.Decimal(36, 18)
  fillPrice                Decimal              @db.Decimal(36, 18)
  cumulativeFilledNotional Decimal              @db.Decimal(36, 18)
  cumulativeFilledQuantity Decimal              @db.Decimal(36, 18)
  orderStatus              ExecutionOrderStatus
  filledAt                 DateTime
  createdAt                DateTime             @default(now())
  updatedAt                DateTime             @updatedAt
  order                    ExecutionOrder       @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@unique([orderId, sequence])
  @@index([portfolioId, instrumentId])
  @@schema("execution_engine")
}

enum OutboxEventStatus {
  PENDING
  IN_FLIGHT
  DISPATCHED
  FAILED

  @@schema("execution_engine")
}

model OutboxEvent {
  id                String            @id
  topic             String
  key               String
  value             Bytes
  headers           Json?
  lifecycleSequence Int               @default(0)
  status            OutboxEventStatus @default(PENDING)
  attempts          Int               @default(0)
  nextAttemptAt     DateTime          @default(now())
  lastError         String?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  dispatchedAt      DateTime?

  @@index([status, nextAttemptAt, lifecycleSequence])
  @@schema("execution_engine")
}
