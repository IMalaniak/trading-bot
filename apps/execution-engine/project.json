{
  "name": "execution-engine",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/execution-engine/src",
  "projectType": "application",
  "tags": [],
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "command": "webpack-cli build",
        "args": ["--node-env=production"],
        "cwd": "apps/execution-engine"
      },
      "configurations": {
        "development": {
          "args": ["--node-env=development"]
        }
      }
    },
    "prune-lockfile": {
      "dependsOn": ["build"],
      "cache": true,
      "executor": "@nx/js:prune-lockfile",
      "outputs": [
        "{workspaceRoot}/dist/apps/execution-engine/package.json",
        "{workspaceRoot}/dist/apps/execution-engine/package-lock.json"
      ],
      "options": {
        "buildTarget": "build"
      }
    },
    "copy-workspace-modules": {
      "dependsOn": ["build"],
      "cache": true,
      "outputs": [
        "{workspaceRoot}/dist/apps/execution-engine/workspace_modules"
      ],
      "executor": "@nx/js:copy-workspace-modules",
      "options": {
        "buildTarget": "build"
      }
    },
    "prune": {
      "dependsOn": ["prune-lockfile", "copy-workspace-modules"],
      "executor": "nx:noop"
    },
    "serve": {
      "continuous": true,
      "executor": "@nx/js:node",
      "defaultConfiguration": "development",
      "dependsOn": ["build"],
      "options": {
        "buildTarget": "execution-engine:build",
        "runBuildTargetDependencies": false
      },
      "configurations": {
        "development": {
          "buildTarget": "execution-engine:build:development",
          "port": 9231
        },
        "production": {
          "buildTarget": "execution-engine:build:production"
        },
        "e2e": {
          "buildTarget": "execution-engine:build:production",
          "runBuildTargetDependencies": false,
          "watch": false
        }
      }
    },
    "serve-e2e": {
      "continuous": true,
      "executor": "@nx/js:node",
      "cache": false,
      "defaultConfiguration": "e2e",
      "dependsOn": [
        {
          "projects": "trading-bot-e2e",
          "target": "e2e-seed"
        }
      ],
      "options": {
        "buildTarget": "execution-engine:build:production",
        "runBuildTargetDependencies": false,
        "watch": false
      },
      "configurations": {
        "e2e": {}
      }
    },
    "test-integration": {
      "executor": "nx:run-commands",
      "cache": false,
      "options": {
        "cwd": "{workspaceRoot}",
        "parallel": false,
        "commands": [
          {
            "command": "npx nx run execution-engine:migrate:test-integration"
          },
          {
            "command": "vitest run --config apps/execution-engine/vitest.integration.config.mts"
          }
        ]
      }
    },
    "migrate": {
      "executor": "nx:run-commands",
      "cache": false,
      "defaultConfiguration": "development",
      "options": {
        "cwd": "apps/execution-engine"
      },
      "configurations": {
        "development": {
          "command": "npx prisma migrate dev"
        },
        "production": {
          "command": "npx prisma migrate deploy"
        },
        "test-integration": {
          "command": "npx prisma migrate reset --force"
        },
        "e2e": {
          "command": "npx prisma migrate reset --force"
        }
      }
    },
    "prisma-generate": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "apps/execution-engine",
        "commands": [
          {
            "command": "rm -rf src/prisma/generated"
          },
          {
            "command": "npx prisma generate"
          },
          {
            "command": "npx nx run execution-engine:lint --fix"
          }
        ]
      }
    },
    "test": {
      "executor": "@nx/vitest:test",
      "options": {
        "configFile": "apps/execution-engine/vitest.config.mts"
      }
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "{workspaceRoot}",
        "command": "tsc -b apps/execution-engine/tsconfig.json --pretty false"
      }
    }
  }
}
