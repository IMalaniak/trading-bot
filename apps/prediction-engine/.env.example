# prediction-engine — local environment variables
#
# Copy this file to .env for local development.
# Never commit .env with real credentials.
#
# Shared variables such as KAFKA_BROKERS, REDIS_URL, and
# PREDICTION_ENGINE_GRPC_URL live in the workspace-root .env. Only
# prediction-engine-specific overrides belong here.

# ── Kafka ─────────────────────────────────────────────────────────────────────
PREDICTION_ENGINE_KAFKA_CONSUMER_GROUP_ID=prediction-engine

# ── gRPC ──────────────────────────────────────────────────────────────────────
PREDICTION_ENGINE_GRPC_PORT=50055

# ── Signal cache ──────────────────────────────────────────────────────────────
PREDICTION_ENGINE_SIGNAL_CACHE_LIMIT=200
PREDICTION_ENGINE_SIGNAL_CACHE_TTL_SECONDS=86400

# ── Baseline model ────────────────────────────────────────────────────────────
PREDICTION_ENGINE_MODEL_VERSION=baseline-core-v1
PREDICTION_ENGINE_BUY_RSI_MAX=80
PREDICTION_ENGINE_BUY_RETURN_MIN=0
PREDICTION_ENGINE_BUY_MACD_HISTOGRAM_MIN=0
PREDICTION_ENGINE_SELL_RSI_MIN=20
PREDICTION_ENGINE_SELL_RETURN_MAX=0
PREDICTION_ENGINE_SELL_MACD_HISTOGRAM_MAX=0
PREDICTION_ENGINE_PRICE_FEATURE_NAME=ema.close.12

# ── Observability ─────────────────────────────────────────────────────────────
PREDICTION_ENGINE_METRICS_PORT=9106
LOG_LEVEL=info
