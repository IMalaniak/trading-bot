# feature-engineering — local environment variables
#
# Copy this file to .env for local development.
# Never commit .env with real credentials.
#
# Shared variables such as KAFKA_BROKERS and DATA_INGESTION_GRPC_URL live in the
# workspace-root .env. Only feature-engineering-specific overrides belong here.

# ── Kafka ─────────────────────────────────────────────────────────────────────
FEATURE_ENGINEERING_KAFKA_CONSUMER_GROUP_ID=feature-engineering

# ── Data Ingestion warm-up ────────────────────────────────────────────────────
FEATURE_ENGINEERING_WARMUP_BARS_LIMIT=120

# ── Observability ─────────────────────────────────────────────────────────────
FEATURE_ENGINEERING_METRICS_PORT=9105
LOG_LEVEL=info
